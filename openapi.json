{
  "components": {
    "schemas": {
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "HealthResponse": {
        "description": "Shape of the /health response (Step 3+).",
        "properties": {
          "api_version": {
            "title": "Api Version",
            "type": "integer"
          },
          "db": {
            "title": "Db",
            "type": "string"
          },
          "status": {
            "title": "Status",
            "type": "string"
          },
          "version": {
            "title": "Version",
            "type": "string"
          }
        },
        "required": [
          "status",
          "version",
          "api_version",
          "db"
        ],
        "title": "HealthResponse",
        "type": "object"
      },
      "LoginRequest": {
        "description": "Body for POST /auth/login.",
        "properties": {
          "email": {
            "title": "Email",
            "type": "string"
          },
          "password": {
            "title": "Password",
            "type": "string"
          }
        },
        "required": [
          "email",
          "password"
        ],
        "title": "LoginRequest",
        "type": "object"
      },
      "MeResponse": {
        "description": "Response body for GET /auth/me.",
        "properties": {
          "user": {
            "$ref": "#/components/schemas/UserResponse"
          }
        },
        "required": [
          "user"
        ],
        "title": "MeResponse",
        "type": "object"
      },
      "MessageResponse": {
        "description": "Generic message response (used for logout).",
        "properties": {
          "message": {
            "title": "Message",
            "type": "string"
          }
        },
        "required": [
          "message"
        ],
        "title": "MessageResponse",
        "type": "object"
      },
      "SetupRequest": {
        "description": "Body for POST /auth/setup \u2014 create the first admin user.",
        "properties": {
          "email": {
            "title": "Email",
            "type": "string"
          },
          "password": {
            "title": "Password",
            "type": "string"
          }
        },
        "required": [
          "email",
          "password"
        ],
        "title": "SetupRequest",
        "type": "object"
      },
      "SetupStatusResponse": {
        "description": "Response body for GET /auth/setup-status.",
        "properties": {
          "setup_required": {
            "title": "Setup Required",
            "type": "boolean"
          }
        },
        "required": [
          "setup_required"
        ],
        "title": "SetupStatusResponse",
