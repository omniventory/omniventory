# Omniventory — environment variable template
# Copy this file to .env and fill in the values.
# The real .env is git-ignored; only .env.example is committed.

# Required: secret key for session signing (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-me-generate-a-strong-random-key

# Runtime environment: development | production
ENVIRONMENT=production

# SQLite database path (inside the container volume)
DATABASE_URL=sqlite:////app/data/omniventory.db

# Admin user to bootstrap on first run (optional; skip by leaving blank)
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=change-me-strong-password
